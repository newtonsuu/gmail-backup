# Copy this file to ".env" and edit. All values are optional except LABEL_NAME.

# The exact Gmail label to back up (case-sensitive). Nested = "Work/Invoices".
LABEL_NAME=Receipts

# Where to write backups. Point this at your Google Drive for Desktop folder
# to auto-sync into Drive, e.g. G:\My Drive\EmailBackup
# Default: a folder named EmailBackup in your home directory.
# BACKUP_DIR=C:\Users\jericho.james.guanga\EmailBackup

# What to save per email.
SAVE_EML=true
SAVE_HTML=true
INCLUDE_INLINE_IMAGES=false

# Stop after N new emails per run (0 = no limit). Handy for a first test:
# MAX_MESSAGES=20

# OAuth file locations (defaults are fine for most people).
# CREDENTIALS_FILE=credentials.json
# TOKEN_FILE=token.json
